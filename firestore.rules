rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Check if the user is the owner of the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /ai_app/{appId} {
      
      match /users/{userId} {
        // Anyone logged in can read user profiles
        allow read: if isAuthenticated();
        
        // A user can create their own profile document
        allow create: if isAuthenticated() && request.auth.uid == userId;
        
        // A user can update their own profile document,
        // OR any logged-in user can update another user's followers array to follow/unfollow them
        allow update: if isOwner(userId) || (
          isAuthenticated() && 
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers']) &&
          (
            request.resource.data.followers.difference(resource.data.followers).hasOnly([request.auth.uid]) ||
            resource.data.followers.difference(request.resource.data.followers).hasOnly([request.auth.uid])
          )
        );
      }

      match /posts/{postId} {
        // Anyone logged in can read posts
        allow read: if isAuthenticated();
        
        // Anyone logged in can create a post under their own userId
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
        
        // Users can update posts (e.g. liking, reporting, or owner updating)
        allow update: if isAuthenticated() && (
          resource.data.userId == request.auth.uid ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likesCount', 'reports'])
        );
        
        // Users can delete their own posts
        allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      }
    }
  }
}
